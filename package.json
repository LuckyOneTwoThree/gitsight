{
  "name": "gitsight",
  "version": "1.0.0",
  "private": true,
  "description": "GitSight - 开源项目情报与分析工具",
  "author": "GitSight Contributors",
  "license": "MIT",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:desktop": "tsc -p electron/tsconfig.json && electron .",
    "build": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build:desktop": "next build && tsc -p electron/tsconfig.json && electron-builder",
    "pack:desktop": "electron-builder --dir",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"try{require('child_process').execSync('electron-builder install-app-deps',{stdio:'ignore'})}catch(e){}\"",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "autoprefixer": "^10.4.20",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "dompurify": "^3.4.6",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.564.0",
    "mermaid": "^11.15.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.1",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@next/swc-wasm-nodejs": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint-config-next": "^16.2.7",
    "geist": "^1.7.2",
    "globals": "^17.6.0",
    "icns": "^0.1.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "1.3.3",
    "typescript": "5.7.3"
  },
  "build": {
    "appId": "com.gitsight.desktop",
    "productName": "GitSight",
    "copyright": "Copyright © 2025 GitSight Contributors",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist-electron-output",
      "buildResources": "electron/resources"
    },
    "files": [
      "dist-electron/**/*",
      "!dist-electron-output",
      "!node_modules",
      "!src",
      "!app",
      "!components",
      "!lib",
      "!scripts",
      "!.next",
      "!data",
      "!public"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app",
        "filter": [
          "**/*",
          "!data/**",
          "!.data/**",
          "!node_modules/**"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/node_modules",
        "filter": [
          "**/*",
          "!@next/swc-*/**",
          "!@img/sharp-*/**",
          "!better-sqlite3/prebuilds/**",
          "!esbuild/**",
          "!typescript/**",
          "!eslint/**",
          "!@eslint/**",
          "!prettier/**"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/better-sqlite3/build/Release",
        "to": "app/node_modules/better-sqlite3/build/Release",
        "filter": [
          "**/*.node"
        ]
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron/resources",
        "to": "icons",
        "filter": [
          "icon.ico",
          "icon.png",
          "icon.icns"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.ico",
      "artifactName": "GitSight-${version}-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/resources/icon-mac.png",
      "artifactName": "GitSight-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/resources/icon.png",
      "artifactName": "GitSight-${version}.${ext}",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GitSight",
      "artifactName": "GitSight-${version}-Setup.${ext}"
    },
    "asar": true,
    "npmRebuild": false,
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "publish": {
      "provider": "github",
      "owner": "LuckyOneTwoThree",
      "repo": "gitsight"
    }
  }
}
